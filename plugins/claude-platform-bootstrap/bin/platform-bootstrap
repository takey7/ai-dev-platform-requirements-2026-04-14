#!/usr/bin/env bash
set -euo pipefail

if command -v platform >/dev/null 2>&1; then
  exec platform "$@"
fi

if [ -f "./scripts/platform.py" ]; then
  exec python3 "./scripts/platform.py" "$@"
fi

echo "platform CLI not found. Clone the platform source repo or add its bin directory to PATH." >&2
exit 1
